# ==========================================
# SCIM Gateway - Complete Environment Configuration
# ==========================================
# All configuration in ONE file - works for local & server deployment
# ==========================================

# ==========================================
# 🔐 REQUIRED - Security Credentials
# ==========================================

# JWT Secret Key (REQUIRED)
# Generated securely - DO NOT share
JWT_SECRET=cPVO8XANn5o1KOYZCKLtrDQEF8pGRb6madUSE9rB6lA=

# Admin Password (REQUIRED)
# Change this for production!
SCIM_ADMIN_PASSWORD=admin123

# ==========================================
# 🗄️ REQUIRED - Database Configuration
# ==========================================

# MongoDB Atlas Connection String (REQUIRED)
MONGODB_URI=mongodb+srv://anurag:cloud%40123@cluster0.nivrt0z.mongodb.net/scimdb?retryWrites=true&w=majority

# ==========================================
# ⚙️ OPTIONAL - Application Settings
# ==========================================

# Application Name
APP_NAME=scim-app

# Spring Profile (dev, prod, staging)
SPRING_PROFILES_ACTIVE=dev

# Server Port
SERVER_PORT=8181

# Admin Username
ADMIN_USERNAME=admin

# Enable Authentication (true/false)
AUTH_ENABLED=true

# ==========================================
# 🔑 OPTIONAL - JWT Configuration
# ==========================================

# JWT Token Expiration (milliseconds)
# 86400000 = 24 hours
JWT_EXPIRATION=86400000

# ==========================================
# 🌐 OPTIONAL - Server & API Configuration
# ==========================================

# Swagger Server URL (leave empty for relative URLs - recommended!)
SWAGGER_SERVER_URL=

# External API Base URL (for provisioning)
EXTERNAL_API_BASE_URL=

# API Timeout (milliseconds)
API_TIMEOUT=30000

# ==========================================
# 📚 OPTIONAL - Swagger UI Documentation
# ==========================================

# API Information
SWAGGER_API_TITLE=SCIM Gateway - REST API Documentation
SWAGGER_API_VERSION=1.0.0
SWAGGER_API_DESCRIPTION=

# Terms & Contact
SWAGGER_TERMS_OF_SERVICE=
SWAGGER_CONTACT_NAME=
SWAGGER_CONTACT_EMAIL=
SWAGGER_CONTACT_URL=

# License
SWAGGER_LICENSE_NAME=Apache 2.0
SWAGGER_LICENSE_URL=

# External Docs
SWAGGER_EXTERNAL_DOCS_DESCRIPTION=Complete SCIM Gateway Documentation
SWAGGER_EXTERNAL_DOCS_URL=

# ==========================================
# 🌍 OPTIONAL - CORS Configuration
# ==========================================

# Allowed origins (comma-separated, leave empty for all)
APP_CORS_ALLOWED_ORIGINS=

# ==========================================
# 📊 OPTIONAL - SCIM Configuration
# ==========================================

# Pagination
SCIM_MAX_RESULTS=100
SCIM_DEFAULT_COUNT=20
SCIM_BASE_URL=/scim/v2

# ==========================================
# ⚡ OPTIONAL - Provisioning Configuration
# ==========================================

# Scheduled sync (every 5 minutes)
SCIM_PROVISIONING_SYNC_CRON=0 0/5 * * * *
SCIM_PROVISIONING_MAX_RETRIES=3
SCIM_PROVISIONING_JOB_RETENTION_DAYS=7

# ==========================================
# 🔒 OPTIONAL - SSL/TLS (if needed)
# ==========================================

# SERVER_SSL_ENABLED=true
# SERVER_SSL_KEY_STORE=classpath:keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=your-password
# SERVER_SSL_KEY_STORE_TYPE=PKCS12
# SERVER_SSL_KEY_ALIAS=tomcat

# ==========================================
# ✅ READY TO USE!
# ==========================================
# 
# To start: ./server-start.sh
# To test:  curl http://localhost:8181/actuator/health
# Swagger:  http://localhost:8181/swagger-ui.html
#
# ==========================================
