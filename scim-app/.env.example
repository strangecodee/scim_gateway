# SCIM Gateway - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env file to Git!

# ==========================================
# Required - Security
# ==========================================

# JWT Secret (Generate with: openssl rand -base64 32)
# Example: cPVO8XANn5o1KOYZCKLtrDQEF8pGRb6madUSE9rB6lA=
JWT_SECRET=CHANGE-THIS-TO-YOUR-OWN-SECRET-KEY

# Admin Password (Use strong password, 16+ characters)
# Example: tLmmIYs#pdaBD8RE9CfN
SCIM_ADMIN_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD

# ==========================================
# Required - Database
# ==========================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Note: Password must be URL-encoded (@ becomes %40, etc.)
# Example: mongodb+srv://anurag:cloud%40123@cluster0.nivrt0z.mongodb.net/scimdb?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/scimdb?retryWrites=true&w=majority

# ==========================================
# Optional - Application
# ==========================================

# Spring Profile (dev, staging, prod)
SPRING_PROFILES_ACTIVE=prod

# Server Port (default: 8080)
# SERVER_PORT=8080

# JWT Expiration in milliseconds (default: 86400000 = 24 hours)
# JWT_EXPIRATION=86400000

# ==========================================
# Optional - SSL/TLS
# ==========================================

# Enable if not using reverse proxy
# SERVER_SSL_ENABLED=true
# SERVER_SSL_KEY_STORE=classpath:keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=your-password
# SERVER_SSL_KEY_STORE_TYPE=PKCS12
# SERVER_SSL_KEY_ALIAS=tomcat

# ==========================================
# Optional - CORS
# ==========================================

# Comma-separated list of allowed origins
# APP_CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ==========================================
# Notes
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. For production, use secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
# 5. Generate JWT secret: openssl rand -base64 32
# 6. Generate strong password: Use password manager or PowerShell:
#    -join ((33..126) | Get-Random -Count 20 | ForEach-Object {[char]$_})
