# ==========================================
# SCIM Gateway - Complete Environment Configuration
# ==========================================
# This is the SINGLE source of truth for all configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file to Git!
#
# Usage:
#   1. Copy: cp .env.example .env
#   2. Edit: nano .env (or use any editor)
#   3. Run:  ./server-start.sh
# ==========================================

# ==========================================
#  REQUIRED - Security Credentials
# ==========================================

# JWT Secret Key (REQUIRED)
# Generate using: openssl rand -base64 32
# Example output: cPVO8XANn5o1KOYZCKLtrDQEF8pGRb6madUSE9rB6lA=
JWT_SECRET=

# Admin Password (REQUIRED)
# Use strong password, minimum 16 characters
# Example: tLmmIYs#pdaBD8RE9CfN
SCIM_ADMIN_PASSWORD=

# ==========================================
#  REQUIRED - Database Configuration
# ==========================================

# MongoDB Atlas Connection String (REQUIRED)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# IMPORTANT: Password must be URL-encoded (@ becomes %40, etc.)
# Example: mongodb+srv://anurag:cloud%40123@cluster0.nivrt0z.mongodb.net/scimdb?retryWrites=true&w=majority
MONGODB_URI=

# ==========================================
#  OPTIONAL - Application Settings
# ==========================================

# Application Name (default: scim-app)
APP_NAME=scim-app

# Spring Profile (default: dev)
# Options: dev, prod, staging
SPRING_PROFILES_ACTIVE=dev

# Server Port (default: 8181)
SERVER_PORT=8181

# Admin Username (default: admin)
ADMIN_USERNAME=admin

# Enable/Disable Authentication (default: true)
# Set to false to disable auth (development only!)
AUTH_ENABLED=true

# ==========================================
#  OPTIONAL - JWT Configuration
# ==========================================

# JWT Token Expiration in milliseconds (default: 86400000 = 24 hours)
# 1 hour = 3600000
# 24 hours = 86400000
# 7 days = 604800000
JWT_EXPIRATION=86400000

# ==========================================
#  OPTIONAL - Server & API Configuration
# ==========================================

# Swagger/OpenAPI Server URL
# Leave empty for relative URLs (works on any server automatically)
# Examples: http://localhost:8181, https://api.yourdomain.com
SWAGGER_SERVER_URL=

# External API Base URL (for provisioning)
# Leave empty if not using external provisioning
EXTERNAL_API_BASE_URL=

# API Timeout in milliseconds (default: 30000 = 30 seconds)
API_TIMEOUT=30000

# ==========================================
#  OPTIONAL - Swagger UI Documentation
# ==========================================

# API Title (default: SCIM Gateway - REST API Documentation)
SWAGGER_API_TITLE=SCIM Gateway - REST API Documentation

# API Version (default: 1.0.0)
SWAGGER_API_VERSION=1.0.0

# API Description (supports Markdown, use \n for new lines)
# Default description is already set, customize if needed
SWAGGER_API_DESCRIPTION=

# Terms of Service URL
SWAGGER_TERMS_OF_SERVICE=

# Contact Information
SWAGGER_CONTACT_NAME=
SWAGGER_CONTACT_EMAIL=
SWAGGER_CONTACT_URL=

# License Information
SWAGGER_LICENSE_NAME=Apache 2.0
SWAGGER_LICENSE_URL=

# External Documentation
SWAGGER_EXTERNAL_DOCS_DESCRIPTION=Complete SCIM Gateway Documentation
SWAGGER_EXTERNAL_DOCS_URL=

# ==========================================
#  OPTIONAL - CORS Configuration
# ==========================================

# Comma-separated list of allowed origins
# Example: https://your-domain.com,https://admin.your-domain.com
# Leave empty to allow all (development only!)
APP_CORS_ALLOWED_ORIGINS=

# ==========================================
#  OPTIONAL - SSL/TLS Configuration
# ==========================================

# Enable SSL (only if not using reverse proxy like Nginx)
# SERVER_SSL_ENABLED=true
# SERVER_SSL_KEY_STORE=classpath:keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=your-password
# SERVER_SSL_KEY_STORE_TYPE=PKCS12
# SERVER_SSL_KEY_ALIAS=tomcat

# ==========================================
#  OPTIONAL - SCIM Configuration
# ==========================================

# Maximum results per page (default: 100)
SCIM_MAX_RESULTS=100

# Default count per page (default: 20)
SCIM_DEFAULT_COUNT=20

# SCIM Base URL (default: /scim/v2)
SCIM_BASE_URL=/scim/v2

# ==========================================
#  OPTIONAL - Provisioning Configuration
# ==========================================

# Cron expression for scheduled sync (default: every 5 minutes)
# Format: second minute hour day month weekday
# Example: 0 0/5 * * * * = every 5 minutes
SCIM_PROVISIONING_SYNC_CRON=0 0/5 * * * *

# Maximum retry attempts for failed provisioning (default: 3)
SCIM_PROVISIONING_MAX_RETRIES=3

# Job retention days (default: 7)
SCIM_PROVISIONING_JOB_RETENTION_DAYS=7

# ==========================================
#  EXAMPLES - Quick Start Configurations
# ==========================================

# Example 1: Local Development
# -----------------------------------------
# JWT_SECRET=cPVO8XANn5o1KOYZCKLtrDQEF8pGRb6madUSE9rB6lA=
# SCIM_ADMIN_PASSWORD=admin123
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/scimdb
# SPRING_PROFILES_ACTIVE=dev
# SERVER_PORT=8181

# Example 2: Production Server
# -----------------------------------------
# JWT_SECRET=$(openssl rand -base64 32)
# SCIM_ADMIN_PASSWORD=YourVeryStrongPassword123!
# MONGODB_URI=mongodb+srv://prod-user:encoded-pass@cluster.mongodb.net/scimdb
# SPRING_PROFILES_ACTIVE=prod
# SERVER_PORT=8181
# AUTH_ENABLED=true
# SWAGGER_SERVER_URL=https://api.yourdomain.com

# Example 3: Docker Container
# -----------------------------------------
# JWT_SECRET=your-secret-here
# SCIM_ADMIN_PASSWORD=your-password-here
# MONGODB_URI=mongodb://mongo:27017/scimdb
# SPRING_PROFILES_ACTIVE=prod
# SERVER_PORT=8181

# ==========================================
#  QUICK START GUIDE
# ==========================================
#
# 1. Generate JWT Secret:
#    openssl rand -base64 32
#
# 2. Generate Strong Password:
#    openssl rand -base64 16
#
# 3. Get MongoDB URI:
#    - Sign up at https://mongodb.com/cloud/atlas
#    - Create cluster
#    - Create database user
#    - Copy connection string
#    - Replace <password> with URL-encoded password
#
# 4. Update this file (.env) with your values
#
# 5. Start application:
#    ./server-start.sh
#
# 6. Verify:
#    curl http://localhost:8181/actuator/health
#
# 7. Access Swagger UI:
#    http://localhost:8181/swagger-ui.html
#
# ==========================================
#  DEPLOYMENT CHECKLIST
# ==========================================
#
# Before deploying to production:
#  JWT_SECRET is generated (not default)
#  SCIM_ADMIN_PASSWORD is strong (16+ chars)
#  MONGODB_URI points to production database
#  SPRING_PROFILES_ACTIVE=prod
#  AUTH_ENABLED=true
#  SWAGGER_SERVER_URL is set (or empty for relative)
#  Firewall configured (port 8181)
#  SSL/TLS enabled (or use reverse proxy)
#
# ==========================================
#  ADDITIONAL NOTES
# ==========================================
#
# - NEVER commit .env file to Git (it's in .gitignore)
# - For production, use secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
# - All variables with defaults can be commented out to use default value
# - Required variables (JWT_SECRET, SCIM_ADMIN_PASSWORD, MONGODB_URI) MUST be set
# - URL-encode special characters in passwords (@ = %40, # = %23, etc.)
# - Use https://www.urlencoder.org/ to encode passwords
#
# ==========================================
